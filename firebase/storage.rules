rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function memberDoc(groupId) {
      return /databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid);
    }

    function isGroupMember(groupId) {
      return signedIn() && firestore.exists(memberDoc(groupId));
    }

    match /groups/{groupId}/sightings/{fileName} {
      allow read: if isGroupMember(groupId);
      allow write: if isGroupMember(groupId);
    }
  }
}